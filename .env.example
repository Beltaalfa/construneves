# Firebird (caminho é o do servidor Windows onde o Firebird roda)
FIREBIRD_HOST=100.84.122.3
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:/MT/Clipp/Base/CLIPP.FDB
# Contas a receber (painel + WhatsApp + resumo): por omissão TB_CONTA_RECEBER (sem _2).
# Só se a base tiver duplicata MT com sufixo _2:
# CONSTRUNEVES_RECEBER_TABELA_SUFFIX=_2
# Por omissão (1): só clientes com NF MT finalizada (TB_NFVENDA_2) — evita alerta com dívidas só CLIPP.
# CONSTRUNEVES_RECEBER_EXIGE_CLIENTE_NF_MT=0
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=changeme

# Porta do painel Next no servidor (tem de ser a mesma do proxy_pass no Nginx; produção típica 3001)
PORT=3001

# Painel Next.js (opcional — se vazio, login desativado)
PAINEL_PASSWORD=
PAINEL_SESSION_SECRET=altere-para-uma-string-longa-aleatoria

# SSO via HUB (padrão Applyfy): quando ativo, ignora PAINEL_PASSWORD e usa JWT do HUB.
# CONSTRUNEVES_AUTH_ENABLED=1
# HUB_AUTH_ENABLED=1
# HUB_LOGIN_URL=https://hub.northempresarial.com/login
# HUB_LOGIN_RETURN_PARAM=callbackUrl
# NEXT_PUBLIC_CONSTRUNEVES_URL=https://construneves.northempresarial.com
# (URL pública do painel: login Hub, Open Graph / PWA metadataBase — sem barra final)
# Nome do cookie JWT enviado pelo HUB (default: access_token)
# CONSTRUNEVES_JWT_COOKIE_NAME=construneves_access_token
# NEXTAUTH_URL=https://hub.northempresarial.com
# HUB_INTERNAL_URL=http://127.0.0.1:3007
# Após o admin alterar telas, cada utilizador deve abrir GET /api/auth/hub-refresh-jwt (link na página Permissões)
# ou voltar a entrar pelo Hub — o JWT no cookie só é reemitido pelo Hub (/hub/bridge).
# HUB_CONSTRUNEVES_COOKIE_NAME=access_token
# Segredo para validar o JWT (preferência nesta ordem):
# HUB_CONSTRUNEVES_JWT_SECRET / CONSTRUNEVES_JWT_SECRET / HUB_APPLYFY_JWT_SECRET / HUB_JWT_SECRET
# HUB_CONSTRUNEVES_JWT_SECRET=

# URL da API Python interna (Route Handlers do Next usam isso no servidor)
PAINEL_INTERNAL_API=http://127.0.0.1:8091

# Alerta de estoque negativo (WhatsApp via WAHA) — painel-api
# WAHA_BASE_URL=https://waha.exemplo.com
# WAHA_API_KEY=
# WAHA_SESSION=default
# WHATSAPP_ALERTA_ESTOQUE_PARA=5537996704090
# ALERTA_ESTOQUE_ESTADO_PATH=/var/www/construneves/data/estoque_alerta_negativo_state.json
# ALERTA_ESTOQUE_CHAVE=defina-uma-senha-para-o-cron
# ALERTA_ESTOQUE_DESLIGADO=0
# A cada N segundos, verifica transição p/ estoque negativo e envia WhatsApp. 0 = sem loop (só HTTP/cron)
# ALERTA_ESTOQUE_INTERVALO_SEG=30
# ALERTA_DRY_RUN=0
# Lista de destinatários editável no painel /notificacoes (JSON: recipients + recipientsCobranca).
# Se recipients vazio, usa WHATSAPP_ALERTA_ESTOQUE_PARA; se recipientsCobranca vazio, WHATSAPP_COBRANCA_ATRASO_PARA.
# NOTIFICACOES_DESTINATARIOS_PATH=/var/www/construneves/data/notificacoes_destinatarios.json

# Negativos → pedido de compra aberto (POST /notificacoes/pedido-compra-negativos; botão no painel Notificações)
# Usa a ordem mais recente não finalizada/cancelada (ver ped_compra_ordem_aberta_atual.sql). Quantidade = |QTD_ATUAL|.
# Se a linha já existir na ordem, soma à QTD_ITEM.
# CONSTRUNEVES_PED_COMPRA_NEGATIVOS=0
# CONSTRUNEVES_PED_COMPRA_DRY_RUN=0
# Forçar uma ordem específica (opcional): CONSTRUNEVES_PED_COMPRA_ID_ORDEM=123
# CONSTRUNEVES_PED_COMPRA_ITEM_TAB=TB_PED_COMPRA_ORDEM_ITEM
# CONSTRUNEVES_PED_COMPRA_COL_PED=ID_PED_COMPRA_ORDEM
# CONSTRUNEVES_PED_COMPRA_COL_IDENT=ID_IDENTIFICADOR
# CONSTRUNEVES_PED_COMPRA_COL_QTD=QTD_ITEM
# Preço unitário no INSERT (muitas bases têm VLR_UNIT NOT NULL). Omitir coluna: CONSTRUNEVES_PED_COMPRA_COL_VLR_UNIT=
# CONSTRUNEVES_PED_COMPRA_COL_VLR_UNIT=VLR_UNIT
# CONSTRUNEVES_PED_COMPRA_VLR_UNIT_DEFAULT=0
# Se a tabela exige PK da linha: CONSTRUNEVES_PED_COMPRA_ITEM_PK=ID_PED_COMPRA_ORDEM_ITEM
# CONSTRUNEVES_PED_COMPRA_ITEM_GEN=GEN_TB_PED_COMPRA_ORDEM_ITEM
# Automático no loop: quando item entrar em QTD_ATUAL <= 0 (zero/negativo), adiciona na ordem aberta.
# Primeira execução só inicializa estado (não insere os já zerados/negativos).
# CONSTRUNEVES_PED_COMPRA_AUTO_NAO_POSITIVO=0
# CONSTRUNEVES_PED_COMPRA_AUTO_ESTADO_PATH=/var/www/construneves/data/ped_compra_auto_nao_positivo_state.json
#
# Teste no servidor (requer jq ou python3): bash /var/www/construneves/deploy/ped-compra-negativos-test.sh

# Apontamentos de cobrança no MT (TB_CLI_CONT_AGENDADO)
# COBRANCA_ID_FUNC_DEFAULT=1
# FIREBIRD_CHARSET_COBRANCA=WIN1252
#
# Alerta diário WhatsApp — clientes com título > N dias em atraso, sem apontamento no mês e sem baixa no mês
# (WAHA: mesmas WAHA_BASE_URL / WAHA_API_KEY / WAHA_SESSION do estoque)
# WHATSAPP_COBRANCA_ATRASO_PARA=5534988070651
# COBRANCA_ATRASO_DIAS=60
# COBRANCA_ALERTA_CHAVE=senha-para-cron-cobranca
# COBRANCA_ALERTA_ATRASO_DESLIGADO=0
# COBRANCA_ALERTA_ATRASO_DRY_RUN=0
# Cron: curl -sS -H 'X-Alerta-Chave: SENHA' http://127.0.0.1:8091/dash/cobranca/alerta-atraso/executar
# Teste sem enviar: .../dash/cobranca/alerta-atraso/teste  ou  POST /notificacoes/cobranca-alerta-atraso-60d/teste
